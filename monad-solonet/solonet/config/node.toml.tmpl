{{ $peers := coll.Slice -}}
{{- range (datasource "peers") -}}
    {{- $path := printf "/shared/peers/%s" . -}}
    {{- $peer := file.Read $path | data.YAML -}}
    {{- $peers = coll.Append $peer $peers -}}
{{- end -}}

beneficiary = "0x0000000000000000000000000000000000000000"
node_name = "{{ .node_name }}"
network_name = "solonet"
ipc_tx_batch_size = 500
ipc_max_queued_batches = 6
ipc_queued_batches_watermark = 3
statesync_threshold = 600
statesync_max_concurrent_requests = 5

chain_id = 20143

[fullnode_raptorcast]
enable_publisher = true
enable_client = true
raptor10_fullnode_redundancy_factor = 3.0
max_group_size = 10
round_span = 240
invite_lookahead = 120
max_invite_wait = 10
deadline_round_dist = 10
init_empty_round_span = 23
max_num_group = 3
invite_future_dist_min = 1
invite_future_dist_max = 600
invite_accept_heartbeat_ms = 10000

[peer_discovery]
self_address = "{{ .address }}"
self_auth_port = {{ .auth_port }}
self_record_seq_num = {{ .self_record_seq_num }}
self_name_record_sig = "{{ .self_name_record_sig }}"
refresh_period = 120
request_timeout = 5
unresponsive_prune_threshold = 5
last_participation_prune_threshold = 5000
min_num_peers = 0
max_num_peers = 200
ping_rate_limit_per_second = 100

[network]
bind_address_host = "0.0.0.0"
bind_address_port = 8000
authenticated_bind_address_port = 8001
max_rtt_ms = 300
max_mbps = 1000

[fullnode_raptorcast.full_nodes_prioritized]
identities = []

[blocksync_override]
peers = []

[statesync]
expand_to_group = true
init_peers = []

{{- $hasDedicated := false }}
{{ range $peers }}

{{- if eq .node_type "validator" }}
# {{ .node_name }}
[[bootstrap.peers]]
address = "{{ .address }}"
record_seq_num = {{ .self_record_seq_num }}
name_record_sig = "{{ .self_name_record_sig }}"
secp256k1_pubkey = "{{ .secp256k1.public_key }}"
auth_port = {{ .auth_port }}

{{ end -}}

{{- if eq .node_type "dedicated" }}
{{- $hasDedicated = true }}
# {{ .node_name }}
[[fullnode_dedicated.identities]]
secp256k1_pubkey = "{{ .secp256k1.public_key }}"
[[bootstrap.peers]]
address = "{{ .address }}"
record_seq_num = {{ .self_record_seq_num }}
name_record_sig = "{{ .self_name_record_sig }}"
secp256k1_pubkey = "{{ .secp256k1.public_key }}"
auth_port = {{ .auth_port }}

{{ end -}}

{{ end }}

{{- if not $hasDedicated }}
[fullnode_dedicated]
identities = []
{{- end }}
